# Base de datos
DATABASE_URL="postgresql://user:password@localhost:5432/taskmanager"

# Auth.js
AUTH_SECRET="genera-uno-con: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Cifrado de credenciales (32 bytes en hex)
# genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="genera-32-bytes-en-hex"

# Google OAuth (del deployment, ver Google Cloud Console) — Fase 7
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# LLM por defecto de la demo (opcional, acotado con rate limit) — Fase 5
DEFAULT_LLM_PROVIDER="anthropic"
DEFAULT_LLM_API_KEY=""
